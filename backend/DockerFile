# ---------- build stage ----------
FROM rust:bookworm AS builder

WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY . .
RUN apt-get update && apt-get install -y sqlite3 && rm -rf /var/lib/apt/lists/*
RUN sqlite3 /tmp/build.db < migrations/20260316000003_create_packages_table.up.sql
RUN DATABASE_URL=sqlite:///tmp/build.db cargo build --release

# ---------- runtime stage ----------
FROM mcr.microsoft.com/dotnet/sdk:8.0-bookworm-slim

WORKDIR /app

ARG NODE_MAJOR=22

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        gnupg \
        python3 \
        python3-venv \
    && curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# cdxgen — generates CycloneDX SBOMs.
RUN npm install -g @cyclonedx/cdxgen

# Android workload — needed for dotnet restore with net8.0-android TFM.
RUN dotnet workload install android

RUN dotnet --version \
    && node --version \
    && cdxgen --version

COPY --from=builder /app/target/release/rust-service /app/backend

EXPOSE 5000

CMD ["./backend"]
