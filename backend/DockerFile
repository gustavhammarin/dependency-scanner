# ---------- build stage ----------
FROM rust:bookworm AS builder

WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY . .
RUN DATABASE_URL=sqlite:///tmp/build.db cargo build --release

# ---------- runtime stage ----------
FROM mcr.microsoft.com/dotnet/sdk:8.0-bookworm-slim

WORKDIR /app

ARG JADX_VERSION=1.5.0
ARG NODE_MAJOR=22

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        unzip \
        gnupg \
        default-jre-headless \
        python3 \
        python3-venv \
    && curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# cdxgen — generates CycloneDX SBOMs (used for dependency scanning).
RUN npm install -g @cyclonedx/cdxgen

# Android workload — needed for dotnet restore with net8.0-android TFM.
RUN dotnet workload install android

# ilspycmd — decompiles .NET DLLs to C# source.
RUN dotnet tool install --tool-path /usr/local/bin ilspycmd

# jadx — decompiles Android/Java AARs and JARs.
RUN curl -fsSL "https://github.com/skylot/jadx/releases/download/v${JADX_VERSION}/jadx-${JADX_VERSION}.zip" \
      -o /tmp/jadx.zip \
    && unzip -q /tmp/jadx.zip -d /opt/jadx \
    && ln -s /opt/jadx/bin/jadx /usr/local/bin/jadx \
    && rm /tmp/jadx.zip

RUN dotnet --version \
    && node --version \
    && cdxgen --version \
    && ilspycmd --version \
    && jadx --version

COPY --from=builder /app/target/release/backend /app/backend

EXPOSE 5000

CMD ["./backend"]
